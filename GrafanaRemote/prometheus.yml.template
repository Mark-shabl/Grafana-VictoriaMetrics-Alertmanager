global:
  scrape_interval: 15s

scrape_configs:
  - job_name: node_exporter
    static_configs:
      - targets:
          - 127.0.0.1:19100
        labels:
          env: remote
          # Из REMOTE_NAME в .env (подстановка при старте vmagent — см. docker-compose.yml)
          instance: __REMOTE_NAME__

  - job_name: cadvisor
    static_configs:
      - targets:
          - 127.0.0.1:18080
        labels:
          env: remote
          instance: __REMOTE_NAME__
