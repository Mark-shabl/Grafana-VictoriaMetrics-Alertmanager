# Central server — copy to `.env` and adjust.
# Внутренние хосты — по DNS-имени (не IP). Убедитесь, что central резолвит эти имена
# (корпоративный DNS, Pi-hole, split-DNS или /etc/hosts на хосте Docker).

# Имя central для remote/.env: CENTRAL_URL=http://${CENTRAL_HOST}:8428
CENTRAL_HOST=monitoring.lan

# SNMP community (RouterOS v2c), тот же, что в /snmp/community на MikroTik. Нужен для сервиса snmp_exporter.
# MIKROTIK_SNMP_COMMUNITY=CHANGEME

# Цель SNMP для vmagent (job snmp_mikrotik / snmp_if_mib). Обычно то же устройство, что и API.
# MIKROTIK_SNMP_TARGET=mikrotik.lan

# ── MKTXP (RouterOS API → экспортёр на 127.0.0.1:49090) ─────────────────
# MKTXP_PROFILE=full — максимум коллекторов MKTXP (DHCP leases, IPv6, туннели, BGP и т.д.).
# poe и w60g по умолчанию ВЫКЛ. (на CRS без PoE/W60G иначе ошибки API в логах). Включите только при наличии железа:
# MKTXP_POE=True
# MKTXP_W60G=True
# Облегчённый режим CRS: MKTXP_PROFILE=crs (тогда см. MKTXP_DHCP / MKTXP_DHCP_LEASE).
# MKTXP_PROFILE=full
# MIKROTIK_API_HOST=mikrotik.lan
# MIKROTIK_API_PORT=8728
# MKTXP_USE_SSL=False
# MKTXP_PLAINTEXT_LOGIN=True
# MKTXP_ROUTER_SECTION=CRS326
#
# только при MKTXP_PROFILE=crs (или minimal / switch):
# MKTXP_DHCP=False
# MKTXP_DHCP_LEASE=False
#
# MIKROTIK_API_USER=mktxp_user
# MIKROTIK_API_PASSWORD=CHANGEME
#
# Если snmp_exporter не резолвит .lan из контейнера (127.0.0.53), укажите IP вашего DNS:
# INTERNAL_DNS=192.168.1.1
