# Central server — copy to `.env` and adjust.
# CENTRAL_HOST=192.168.1.100
# Remote write URL for remote/.env: http://${CENTRAL_HOST}:8428

# SNMP community (RouterOS v2c), тот же, что в /snmp/community на MikroTik. Нужен для сервиса snmp_exporter.
# MIKROTIK_SNMP_COMMUNITY=CHANGEME

# MKTXP (RouterOS API → экспортёр на 127.0.0.1:49090). На устройстве включите API (/ip service) и допустите TCP 8728 с центра; пользователь только policy=api,read — см. README.
# MIKROTIK_API_HOST=192.168.88.1
# MIKROTIK_API_PORT=8728
# MKTXP_USE_SSL=False
# MKTXP_PLAINTEXT_LOGIN=True
# MKTXP_ROUTER_SECTION=CRS326
# MKTXP_POE=False
# MIKROTIK_API_USER=mktxp_user
# MIKROTIK_API_PASSWORD=CHANGEME

