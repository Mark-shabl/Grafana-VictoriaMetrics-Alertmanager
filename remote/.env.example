# Обязательно: IP или hostname центрального сервера
# Только http://хост:8428 — без /api/v1/write (путь добавляет docker-compose у vmagent)
CENTRAL_URL=http://192.168.1.100:8428

# Имя этого сервера: лейбл host в VictoriaMetrics, instance в scrape (редоктируйте только здесь).
# Переименовано из HOSTNAME, чтобы переменная shell HOSTNAME не ломала docker compose под Linux.
REMOTE_NAME=server1
